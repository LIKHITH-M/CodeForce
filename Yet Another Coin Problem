package org.likhith;

import java.io.BufferedReader;
import java.io.IOException;
import java.io.InputStreamReader;
import java.util.Arrays;

public class P1934B {
    public static void main(String args[]) throws IOException {

        /*
         * B. Yet Another Coin Problem
         *
         * Coins available (unlimited):
         * 1, 3, 6, 10, 15
         *
         * Goal:
         * Find the minimum number of coins needed to obtain exactly n.
         *
         * Constraints:
         * n ≤ 1e9, so O(n) DP is impossible.
         *
         * Core idea:
         * - For large n, the optimal solution uses mostly 15-value coins.
         * - Pure greedy is not always optimal.
         * - Precompute dp[0...200], where dp[x] = minimum coins needed to make x.
         * - Let q = n / 15.
         * - Try using q, q-1, ..., q-6 fifteen-value coins.
         * - For each choice:
         *
         *      remainder = n - 15 * used15
         *      answer = used15 + dp[remainder]
         *
         * - Take the minimum over all choices.
         *
         * Since removing at most 6 coins of value 15 increases the remainder
         * by at most 6*15 = 90, a DP table up to 200 is sufficient.
         */

        BufferedReader br = new BufferedReader(new InputStreamReader(System.in));
        int T = Integer.parseInt(br.readLine());

        // dp[x] = minimum coins required to make sum x
        int[] change = new int[201];
        Arrays.fill(change, 100);
        change[0] = 0;

        int[] coins = {1, 3, 6, 10, 15};

        // Precompute small sums once
        for (int i = 1; i < 201; i++) {
            for (int coin : coins) {
                if (coin > i) break;
                change[i] = Math.min(change[i], 1 + change[i - coin]);
            }
        }

        while (T-- > 0) {

            long sum = Long.parseLong(br.readLine());

            long res = Integer.MAX_VALUE;
            long q = sum / 15;
            long limit = Math.min(q, 6);

            if (sum < 201) {
                res = change[(int) sum];
            } else {
                // Try reducing the number of 15-value coins
                for (int i = 0; i <= limit; i++) {
                    long used15 = q - i;
                    long rem = sum - 15 * used15;

                    res = Math.min(res, used15 + change[(int) rem]);
                }
            }

            System.out.println(res);
        }
    }
}
